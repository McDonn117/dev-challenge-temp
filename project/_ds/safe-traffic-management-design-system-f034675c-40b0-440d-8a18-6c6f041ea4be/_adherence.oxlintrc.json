{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/**",
              "components/badges/**",
              "components/buttons/**",
              "components/cards/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/console/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|mono|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, icon, mono, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|orange|blue|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'orange' | 'blue' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|disabled|as|href|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth, disabled, as, href, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:accent|accentSide|pad|interactive|inverse|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: accent, accentSide, pad, interactive, inverse, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:orange|blue)$/]",
        "message": "<Card> accent must be one of 'orange' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accentSide'] > Literal[value!=/^(?:left|top)$/]",
        "message": "<Card> accentSide must be one of 'left' | 'top'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|icon|required|multiline|rows|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, icon, required, multiline, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|as|children|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: color, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:orange|blue|muted|onDark)$/]",
        "message": "<Kicker> color must be one of 'orange' | 'blue' | 'muted' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconColor|title|description|linkLabel|href|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: icon, iconColor, title, description, linkLabel, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute[name.name='iconColor'] > Literal[value!=/^(?:orange|blue)$/]",
        "message": "<ServiceCard> iconColor must be one of 'orange' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|logoAlt|links|activeHref|cta|secondaryCta|sticky|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: logoSrc, logoAlt, links, activeHref, cta, secondaryCta, sticky."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|caption|color|size|onDark|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, caption, color, size, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:default|orange|blue|onDark)$/]",
        "message": "<Stat> color must be one of 'default' | 'orange' | 'blue' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Stat> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pass|warn|fail|info|neutral)$/]",
        "message": "<StatusPill> status must be one of 'pass' | 'warn' | 'fail' | 'info' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
